{
  "name": "@xianlinyi/agent-memory",
  "version": "0.1.7",
  "description": "External agent memory layer backed by Obsidian Markdown and SQLite FTS5.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "amem": "./dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/cli.test.js dist/test/copilot-cli-provider.test.js dist/test/engine.test.js dist/test/frontmatter.test.js dist/test/sdk-config.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "benchmark:ingest": "npm run build && node scripts/benchmark-ingest.mjs"
  },
  "keywords": [
    "agent",
    "memory",
    "knowledge-graph",
    "obsidian",
    "sqlite",
    "fts5"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
